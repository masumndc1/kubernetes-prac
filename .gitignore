# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which likely contain sensitive data
*.tfvars
*.tfvars.json

# Ignore operator override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plugin cache
.terraform.d/plugin-cache

# ignore local helm file
tf/cilium/*
tf/tetragon/*
tf/kyverno/*
tf/.terraform*
tf/.terraform.lock.hcl
